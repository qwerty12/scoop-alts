            "hash": "c9c10529a765bbd01e4cfb01c518634340f3e7d9f9364f759f1f3cefc49fb11e"
        },
        "arm64": {
            "url": "https://github.com/jellyfin/jellyfin-ffmpeg/releases/download/v7.1.3-5/jellyfin-ffmpeg_7.1.3-5_portable_winarm64-clang-gpl.zip",
            "hash": "6653b540836f8a24ec68c088a34508a7fe5c5f7364a7d054f0d311b065707ca5"
